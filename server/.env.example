# Server Config
PORT=3000

# Prisma / Postgres
# Kết nối Supabase PostgreSQL theo yêu cầu
DATABASE_URL="postgres://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# JWT Auth
JWT_ACCESS_SECRET="your-super-secret-access-key"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_REFRESH_EXPIRES="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxx"

# Elasticsearch
ELASTICSEARCH_NODE="http://localhost:9200"

# RapidAPI Configuration
RAPIDAPI_KEY="your-rapidapi-key-here"
JSEARCH_API_HOST="jsearch.p.rapidapi.com"
LINKEDIN_API_HOST="linkedin-job-search-api.p.rapidapi.com"
JOB_POSTING_FEED_HOST="job-posting-feed-api.p.rapidapi.com"
