// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres123@localhost:5432/workly"
}



enum AuthProvider {
  LOCAL
  GOOGLE
  LINKEDIN
}

enum StatusUser {
  ACTIVE
  LOCKED
}

enum CrawlStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum FilterAction {
  EXCLUDE
  INCLUDE
}

enum JobType {
  FULLTIME
  PARTTIME
  INTERNSHIP
}

enum PostType {
  CRAWLED
  MANUAL
}

enum AppStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum RawJobStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}

model User {
  userId   String     @id @default(uuid())
  email    String     @unique
  password String?
  status   StatusUser

  provider      AuthProvider @default(LOCAL)
  providerId    String?

  createdAt       DateTime  @default(now())
  lastLogin       DateTime?
  phoneNumber     String?
  avatar          String?
  isEmailVerified Boolean   @default(false)
  updatedAt       DateTime  @updatedAt
  refreshToken    String?

  admin     Admin?
  candidate Candidate?
  recruiter Recruiter?

  userRoles UserRole[]
  notifications Notification[]
}

model Role {
  roleId   String @id @default(uuid())
  roleName String @unique // e.g., "CANDIDATE", "RECRUITER", "ADMIN"

  userRoles UserRole[]
}

model UserRole {
  userRoleId String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [userId])
  role Role @relation(fields: [roleId], references: [roleId])

  @@unique([userId, roleId])
}

model Notification {
  notificationId String   @id @default(uuid())
  title          String
  message        String
  type           String   @default("info") // 'success', 'info', 'warning', 'error'
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [userId])
}

model Admin {
  adminId    String  @id @default(uuid())
  adminLevel Int
  lastAction String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [userId])


  companies    Company[]
}

model Candidate {
  candidateId String  @id @default(uuid())
  fullName    String
  university  String?
  major       String?
  gpa         Float?
  cvUrl       String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [userId])

  skills        Skill[]
  cvs           CV[]
  applications  Application[]
  savedJobs     SavedJob[]
  conversations Conversation[]
}

model Skill {
  skillId   String @id @default(uuid())
  skillName String

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId])
}

model Recruiter {
  recruiterId String  @id @default(uuid())
  bio         String?
  position    String?
  savedCandidateIds String[] // Array to store favorite candidate IDs

  userId String @unique
  user   User   @relation(fields: [userId], references: [userId])

  jobPostings   JobPosting[]
  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [companyId])
  conversations Conversation[]
}


model CrawlLog {
  crawlLogId     String      @id @default(uuid())
  providerName   String
  status         CrawlStatus
  startTime      DateTime    @default(now())
  endTime        DateTime?
  itemsProcessed Int?
  errorMessage   String?
}

model Company {
  companyId          String  @id @default(uuid())
  companyName        String
  taxCode            String? @unique
  isRegistered       Boolean @default(false)
  verifyStatus       Int     @default(0)
  logo               String?
  banner             String?
  address            String?
  description        String?
  websiteUrl         String?
  companySize        Int?
  businessLicenseUrl String?

  adminId     String?
  admin       Admin?      @relation(fields: [adminId], references: [adminId])
  recruiters  Recruiter[]
  jobPostings JobPosting[]
}



model RawJob {
  rawJobId    String   @id @default(uuid())
  source      String
  fingerprint String   @unique
  rawPayload  Json
  title       String?
  companyName String?
  location    String?
  originalUrl String?
  jobType     String?
  
  status      RawJobStatus   @default(PENDING)
  errorMessage String?
  
  lastSeenAt  DateTime @default(now()) @db.Timestamp
  createdAt   DateTime @default(now()) @db.Timestamp
  updatedAt   DateTime @updatedAt @db.Timestamp
  
  jobPosting  JobPosting?
}

model JobPosting {
  jobPostingId       String    @id @default(uuid())
  title              String
  description        String?
  requirements       String?
  benefits           String?
  salaryMin          Decimal?  @db.Decimal(19, 0)
  salaryMax          Decimal?  @db.Decimal(19, 0)
  currency           String?   @default("VND")
  jobType            JobType?
  experience         String?
  vacancies          Int       @default(1)
  locationCity       String?
  deadline           DateTime? @db.Timestamp
  status             JobStatus @default(PENDING)
  postType           PostType  @default(CRAWLED)
  isVerified         Boolean   @default(false)
  originalUrl        String    @unique
  aiReliabilityScore Float?
  createdAt          DateTime  @default(now()) @db.Timestamp
  updatedAt          DateTime  @updatedAt @db.Timestamp
  approvedBy         String?

  rawJobId           String?   @unique
  rawJob             RawJob?   @relation(fields: [rawJobId], references: [rawJobId])


  recruiterId   String?
  recruiter     Recruiter?   @relation(fields: [recruiterId], references: [recruiterId])
  companyId     String
  company       Company      @relation(fields: [companyId], references: [companyId])
  applications Application[]
  savedJobs    SavedJob[]
}

model CV {
  cvId      String   @id @default(uuid())
  cvTitle   String
  fileUrl   String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId])

  applications Application[]
}

model Application {
  applicationId String    @id @default(uuid())
  applyDate     DateTime  @default(now())
  appStatus     AppStatus @default(PENDING)
  cvSnapshotUrl String
  coverLetter   String?
  feedback      String?

  candidateId  String
  candidate    Candidate  @relation(fields: [candidateId], references: [candidateId])
  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [jobPostingId])
  cvId         String
  cv           CV         @relation(fields: [cvId], references: [cvId])
}

model SavedJob {
  savedJobId String   @id @default(uuid())
  savedAt    DateTime @default(now())

  candidateId  String
  candidate    Candidate  @relation(fields: [candidateId], references: [candidateId])
  jobPostingId String
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [jobPostingId])

  @@unique([candidateId, jobPostingId])
}

model Conversation {
  conversationId String    @id @default(uuid())
  candidateId    String
  candidate      Candidate @relation(fields: [candidateId], references: [candidateId])
  recruiterId    String
  recruiter      Recruiter @relation(fields: [recruiterId], references: [recruiterId])
  lastMessage    String?
  isRead         Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  userId         String?

  messages Message[]
}

model Message {
  messageId String   @id @default(uuid())
  content   String
  sentAt    DateTime @default(now())
  isRead    Boolean  @default(false)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [conversationId])
  senderId       String
}
